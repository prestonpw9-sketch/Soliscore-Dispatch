# Copy to `.env` and fill in real values. Never commit `.env`.
# Vite only exposes variables prefixed with VITE_.

# Required — Supabase (hosted project or local `supabase start`)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional — Google Gemini AI assistant
# Production: store the key in Supabase → Project Settings → Edge Functions → Secrets
# as GEMINI_API_KEY (or VITE_GEMINI_API_KEY). The app calls the gemini-chat edge function.
# Local-only fallback (optional): uncomment and set if you run without deploying the function.
# VITE_GEMINI_API_KEY=

# Optional — Twilio (client-visible phone display only; secrets stay in edge functions)
VITE_TWILIO_PHONE_NUMBER=
