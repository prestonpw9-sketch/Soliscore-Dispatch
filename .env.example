# Copy to `.env` and fill in real values. Never commit `.env`.
# Vite only exposes variables prefixed with VITE_.

# Required — Supabase (hosted project or local `supabase start`)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional — Google Gemini AI assistant
# Create a new key in Google AI Studio / Cloud Console after the old leaked key is revoked.
# Restrict the key by HTTP referrer (e.g. app.solidcoreplumb.com/*) when possible.
VITE_GEMINI_API_KEY=

# Optional — Twilio (client-visible phone display only; secrets stay in edge functions)
VITE_TWILIO_PHONE_NUMBER=
